; Engine configuration file.
; GDScript-first Godoteer demo project.
config_version=5

[application]

config/name="Godoteer GDScript Demo"
run/main_scene="res://scenes/sample_app.tscn"
config/features=PackedStringArray("4.2")

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"

[accessibility]

general/accessibility_support=1

[input]

move_right={
"deadzone": 0.5,
"events": []
}
jump={
"deadzone": 0.5,
"events": []
}
